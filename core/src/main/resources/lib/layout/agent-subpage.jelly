<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:l="/lib/layout" xmlns:d="jelly:define" xmlns:dd="/lib/layout/dropdowns"
         xmlns:st="jelly:stapler">
  <st:documentation>
    A reusable container for subpages relating to Agents in Jenkins.
    Renders a tabbed layout for agents, including agent status and actions.
    <st:attribute name="agent">
      The agent that this page is related to. Used to render agent-specific information and actions in the header.
    </st:attribute>
    <st:attribute name="title" use="required">
      Breadcrumb title.
    </st:attribute>
    <st:attribute name="permission">
      Permission to check for accessing the page.
    </st:attribute>
    <st:attribute name="permissions">
      Permissions to check for accessing the page.
    </st:attribute>
  </st:documentation>

  <l:userExperimentalFlag var="newAgentPage" flagClassName="jenkins.model.experimentalflags.NewAgentPageUserExperimentalFlag" />

  <l:layout title="${attrs.agent.displayName} - ${attrs.title}" permission="${attrs.permission}" permissions="${attrs.permissions}"
            type="${(newAgentPage or not attrs.noSidepanel) ? 'two-column' : 'one-column'}">
    <j:if test="${not empty(attrs.title)}">
      <l:breadcrumb title="${attrs.title}" />
    </j:if>

    <j:choose>
      <j:when test="${newAgentPage}">
        <l:side-panel>
          <j:new className="hudson.model.ManageJenkinsAction" var="manageJenkinsAction" />
          <l:app-bar title="${manageJenkinsAction.displayName}" />

          <l:tasks>
            <l:search-bar placeholder="${%Search}" id="settings-search-bar" />

            <script src="${resURL}/jsbundles/pages/manage-jenkins.js" type="text/javascript" />

            <j:invokeStatic var="j" className="jenkins.model.Jenkins" method="get" />
            <j:forEach var="category" items="${j.categorizedManagementLinks.entrySet()}">
              <summary class="jenkins-side-nav__heading">
                ${category.key.label}
              </summary>
              <j:forEach var="item" items="${category.value}">
                <l:task title="${item.displayName}"
                        href="${rootURL}/manage/${item.urlName}"
                        icon="${item.iconFileName}"
                        badge="${item.badge}"
                        requiresConfirmation="${item.requiresConfirmation}"
                        post="${item.requiresPOST}"
                        confirmationMessage="${%sure}" />
              </j:forEach>
            </j:forEach>
          </l:tasks>
        </l:side-panel>
        <l:main-panel>
          <div class="app-build-bar app-agent-bar">
            <div class="app-build-bar__content">
              <div>
                <l:icon alt="${attrs.agent.description}"
                        src="${attrs.agent.iconClassName}" class="icon-lg" />
              </div>
              <h1>${attrs.agent.caption}</h1>
            </div>

            <j:set var="url" value="${h.getNearestAncestorUrl(request2, attrs.agent)}"/>
            <div class="app-build-bar__tabs">
              <l:tabs items="${attrs.agent.agentTabs}" />
            </div>

            <div class="app-build-bar__controls">
              <st:include page="app-controls.jelly" from="${attrs.agent}" it="${attrs.agent}"/>
              <l:actions it="${attrs.agent}" />
            </div>
          </div>
          <div class="app-settings-container">
            <div class="app-settings-container__inner app-settings-agent-container" >

              <div class="app-build-content app-agent-content">
                <d:invokeBody />
              </div>
            </div>
          </div>
        </l:main-panel>
      </j:when>
      <j:otherwise>
        <st:include page="sidepanel.jelly" it="${attrs.agent}"/>
        <l:main-panel>
          <d:invokeBody />
        </l:main-panel>
      </j:otherwise>
    </j:choose>
  </l:layout>
</j:jelly>
